# ========================================
# DOTKO.IN Web — Environment Variables Template
# ========================================
# Copy this file to .env.local and fill in actual values.
# NEVER commit .env.local to version control.

# Firebase public config (safe for client)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Server-side only (Vercel Serverless Functions)
# Set these in Vercel Dashboard > Settings > Environment Variables
GST_API_KEY=your_live_api_key
GST_API_SECRET=your_live_api_secret
GST_TEST_API_KEY=your_test_api_key
GST_TEST_API_SECRET=your_test_api_secret
GST_USE_TEST_API=true
